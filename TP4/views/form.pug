extends layout

block content
  .w3-card-4
    header.w3-container.w3-purple
      h2= treino ? "Edit Training Record" : "New Training Record"
    
    form.w3-container.w3-padding-16(method="POST" action=treino ? `/treinos/${treino.id}` : "/treinos")
      fieldset
        legend Metadata
        if treino
          input(type="hidden" name="id" value=treino.id)
        
        label Data
        input.w3-input.w3-round(type="text" name="data" value=treino ? treino.data : "")
        
        label Nome
        input.w3-input.w3-round(type="text" name="nome" value=treino ? treino.nome : "")
        
        label Desporto
        input.w3-input.w3-round(type="text" name="desporto" value=treino ? treino.desporto : "")
        
        label Duração
        input.w3-input.w3-round(type="text" name="duracao" value=treino ? treino.duracao : "")
      
      button.w3-btn.w3-purple.w3-margin-top(type="submit")= treino ? "Update" : "Insert"
      a.w3-btn.w3-grey.w3-margin-top.w3-margin-left(href="/") Cancel