extends layout

block content
  style.
    .form-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      max-width: 620px;
    }
    .form-header {
      background: var(--surface2);
      border-bottom: 2px solid var(--accent);
      padding: 1rem 1.5rem;
    }
    .form-header h2 {
      font-family: var(--font-head);
      font-size: 1.1rem;
      font-weight: 800;
    }
    .form-body {
      padding: 1.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group.full { grid-column: 1 / -1; }
    .form-group label {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }
    .form-group input[type="text"],
    .form-group input[type="date"],
    .form-group input[type="email"],
    .form-group select {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 0.82rem;
      padding: 8px 12px;
      transition: border-color 0.2s;
      width: 100%;
    }
    .form-group input:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(0,229,160,0.1);
    }
    .form-group select option { background: var(--bg); }
    .checkbox-row {
      flex-direction: row !important;
      align-items: center;
      gap: 8px;
      padding: 8px 0;
    }
    .checkbox-row input[type="checkbox"] {
      accent-color: var(--accent);
      width: 16px;
      height: 16px;
      cursor: pointer;
    }
    .checkbox-row label {
      font-size: 0.78rem;
      text-transform: none;
      letter-spacing: 0;
      color: var(--text);
      cursor: pointer;
    }
    .form-actions {
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 8px;
    }
    .section-divider {
      grid-column: 1 / -1;
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--accent);
      padding-bottom: 4px;
      border-bottom: 1px solid var(--border);
      margin-top: 4px;
    }

  .form-card
    .form-header
      h2= emd ? "Editar Registo" : "Novo Registo"
    form(method="POST" action=emd ? `/emd/${emd.id}` : "/emd")
      .form-body
        if emd
          input(type="hidden" name="id" value=emd.id)

        .section-divider Identificação

        .form-group
          label Primeiro Nome
          input(type="text" name="nome[primeiro]" value=emd ? emd.nome.primeiro : "" required)
        .form-group
          label Último Nome
          input(type="text" name="nome[ultimo]" value=emd ? emd.nome.último : "" required)
        .form-group
          label Data EMD
          input(type="date" name="dataEMD" value=emd ? emd.dataEMD : "")
        .form-group
          label Idade
          input(type="text" name="idade" value=emd ? emd.idade : "")
        .form-group
          label Género
          select(name="género")
            option(value="M" selected=emd && emd.género === 'M') Masculino
            option(value="F" selected=emd && emd.género === 'F') Feminino

        .section-divider Contacto & Clube

        .form-group.full
          label Morada
          input(type="text" name="morada" value=emd ? emd.morada : "")
        .form-group
          label Modalidade
          input(type="text" name="modalidade" value=emd ? emd.modalidade : "")
        .form-group
          label Clube
          input(type="text" name="clube" value=emd ? emd.clube : "")
        .form-group.full
          label Email
          input(type="text" name="email" value=emd ? emd.email : "")

        .section-divider Estado

        .form-group.checkbox-row
          input(type="checkbox" name="federado" id="federado" checked=emd && emd.federado)
          label(for="federado") Federado
        .form-group.checkbox-row
          input(type="checkbox" name="resultado" id="resultado" checked=emd && emd.resultado)
          label(for="resultado") Apto (Resultado positivo)

      .form-actions
        button.btn.btn-primary(type="submit")= emd ? "Guardar Alterações" : "Inserir Registo"
        a.btn.btn-secondary(href="/") Cancelar
