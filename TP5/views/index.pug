extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Filmes
          a.w3-btn.w3-round.w3-grey.w3-right.w3-margin-right(href="/generos") Géneros
          a.w3-btn.w3-round.w3-grey.w3-right.w3-margin-right(href="/atores") Atores
          a.w3-btn.w3-round.w3-white.w3-right.w3-margin-right(href="/") Filmes

    
    
    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Título
          th Ano
          th Nº Géneros
          th Nº Atores
          th Operações
        each filme in filmes
          tr
            td= filme.id
            td= filme.title
            td= filme.year
            td= filme.genres.length
            td= filme.cast.length
            td
              a.w3-button.w3-blue(href="/filmes/" + filme.id) Ver