extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 #{ator.name}
        a.w3-btn.w3-round.w3-grey.w3-right(href="/atores") ← Voltar
     
    
    .w3-container.w3-padding
      h4 ID : #{ator.id}
      h4 🎬 Filmes em que participa (#{ator.filmes.length})
      
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Título
          th Ano
          th Operações
        each filme in ator.filmes
          tr
            td= filme.id
            td= filme.title
            td= filme.year
            td
              a.w3-button.w3-blue(href="/filmes/" + filme.id) Ver Filme