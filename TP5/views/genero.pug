extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      span.w3-right
        a.w3-btn.w3-round.w3-grey(href="/generos") ← Voltar
      h1 #{genero.name}
    
    .w3-container.w3-padding
      h4 ID : #{genero.id}
      h4 🎬 Filmes neste género (#{genero.filmes.length})
      
      table.w3-table-all.w3-margin-top
        tr
          th ID
          th Título
          th Ano
          th Operações
        each filme in genero.filmes
          tr
            td= filme.id
            td= filme.title
            td= filme.year
            td
              a.w3-button.w3-blue(href="/filmes/" + filme.id) Ver Filme