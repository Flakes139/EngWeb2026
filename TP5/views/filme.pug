extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 #{filme.title} (#{filme.year})
    
    .w3-container.w3-padding
      
      h4 🎭 Géneros
      p= filme.genres.join(", ")
      
      h4 🎬 Elenco
      ul
        each ator in filme.cast
          li= ator
      
      .w3-row
        .w3-half
          p
            b Nº Géneros: 
            | #{filme.genres.length}
        .w3-half
          p
            b Nº Atores: 
            | #{filme.cast.length}
      
      a.w3-button.w3-teal(href="/") ← Voltar